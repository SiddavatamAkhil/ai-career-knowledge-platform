# Copy this file to .env and fill in whichever key you have.
# The app works even with NO key set (it falls back to extractive answers).

# Provider selection: auto | openai | anthropic | extractive
LLM_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
